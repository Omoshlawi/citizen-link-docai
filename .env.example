# ── Database ───────────────────────────────────────────────────────────────────
# docai's OWN PostgreSQL — not shared with NestJS
DATABASE_URL=postgresql://docai:docai_password@db:5432/citizen-link-docai
POSTGRES_PASSWORD=docai_password

# ── Internal auth ──────────────────────────────────────────────────────────────
# Shared secret between NestJS → docai (for /v1/process and /v1/embed)
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=generate-with-openssl-rand-hex-32

# ── NestJS webhook ─────────────────────────────────────────────────────────────
# Where docai sends stage callbacks (progress + final result)
NESTJS_WEBHOOK_URL=http://nestjs-server:2000/api/webhooks/docai/progress
# Secret docai sends on every webhook call — NestJS validates this
NESTJS_INTERNAL_SECRET=same-as-nestjs-INTERNAL_SECRET

# ── Redis (ARQ job queue) ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Vision model ───────────────────────────────────────────────────────────────
# When running in Docker, use host.docker.internal to reach Ollama on the host
VISION_AI_BASE_URL=http://host.docker.internal:11434/v1
VISION_AI_API_KEY=ollama
VISION_AI_MODEL=gemma3:4b

# ── Structure/text extraction model ───────────────────────────────────────────
STRUCTURE_AI_BASE_URL=http://host.docker.internal:11434/v1
STRUCTURE_AI_API_KEY=ollama
STRUCTURE_AI_MODEL=gemma3:4b

# ── Embedding model ────────────────────────────────────────────────────────────
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
# Set to true if using OpenAI's text-embedding-* models instead of Ollama
EMBEDDING_IS_OPENAI=false

# ── Tuning ─────────────────────────────────────────────────────────────────────
# Max correction rounds in vision/structure agents before giving up
MAX_AGENT_ITERATIONS=3
# ARQ retry attempts for failed webhook deliveries
WEBHOOK_MAX_RETRIES=3

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
